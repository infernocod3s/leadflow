# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-key

# OpenAI
OPENAI_API_KEY=sk-your-key

# Email Finding (waterfall: Prospeo → TryKitt → BetterContact)
PROSPEO_API_KEY=your-prospeo-key
TRYKITT_API_KEY=your-trykitt-key
BETTERCONTACT_API_KEY=your-bettercontact-key

# Email Verification (waterfall: Reoon → BounceBan)
REOON_API_KEY=your-reoon-key
BOUNCEBAN_API_KEY=your-bounceban-key

# Smartlead
SMARTLEAD_API_KEY=your-smartlead-key

# Optional
LOG_LEVEL=INFO
DEFAULT_CONCURRENCY=20
